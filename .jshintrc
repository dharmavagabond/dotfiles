{
  "browser"       : true,
  "camelcase"     : true,
  "devel"         : false,
  "eqeqeq"        : true,
  "eqnull"        : true,
  "esnext"        : true,
  "evil"          : true,
  "forin"         : true,
  "immed"         : true,
  "indent"        : 2,
  "jquery"        : false,
  "latedef"       : true,
  "maxcomplexity" : 15,
  "maxdepth"      : 5,
  "maxlen"        : 120,
  "maxparams"     : 5,
  "maxstatements" : 25,
  "newcap"        : true,
  "noarg"         : true,
  "noempty"       : true,
  "onecase"       : true,
  "quotmark"      : true,
  "strict"        : true,
  "undef"         : true,
  "unused"        : "strict",
  "validthis"     : true
}
