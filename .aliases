alias reload="source $HOME/.aliases"
alias gs="git st"
alias ga="git add -p"
alias gb="git br"
alias gc="git cm"
alias gd="git diff"
alias go="git co"
alias gk="gitk --all&"
alias gx="gitx --all"
alias gt="git semtag"
alias gm="git me --no-ff"
alias hist="git hist"
alias phpserver="php -S localhost:8001"
alias color="pygmentize -O style=monokai -f console256 -g"
alias sublpkg="cd $HOME/Library/Application\ Support/Sublime\ Text\ 3/Packages"
alias peso="du -s ./* | sort -n | cut -f 2- | xargs -Ix du -sh x"
alias br="brew update && brew upgrade --all"
alias np="npm update -g"
alias ge="gem update"
alias comp="composer self-update"
alias actualizar="br; ge; comp; np; growlnotify -t 'Actualización' -m 'Todo actual y en orden; casual.'"
alias artisan="php artisan"
alias vaciarpapelera="rm -rfv $HOME/.Trash/*"
alias manage="python manage.py"
alias webgrind="cd $HOME/Sites/webgrind && phpserver"
alias selserver="selenium-server -p 4444"
alias memoria="top -l 1 | ack --no-color 'PhysMem' | growlnotify -t 'Información de memoria'"
alias yt="youtube-dl -f 37/22/18/h264-hd/h264-sd"
alias redis="redis-server /usr/local/etc/redis.conf"
alias postgres="postgres -D /usr/local/var/postgres"
alias crontab="VIM_CRONTAB=true crontab"
