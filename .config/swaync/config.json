{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "cssPriority": "user",
  "notification-inline-replies": false,
  "image-visibility": "when-available",
  "widgets": [
    "title",
    "dnd",
    "notifications",
    "mpris"
  ],
  "widget-config": {
    "notifications": {
      "vexpand": true
    },
    "title": {
      "text": "Notificaciones",
      "clear-all-button": true,
      "button-text": "Clear All"
    },
    "dnd": {
      "text": "No molestar"
    },
    "mpris": {
      "blacklist": [],
      "autohide": false,
      "show-album-art": "always",
      "loop-carousel": false
    }
  }
}
