{
    "label" : "lock",
    "action" : "loginctl lock-session",
    "text" : "Lock",
    "keybind" : "l"
}
{
    "label" : "logout",
    "action" : "omarchy-system-logout",
    "text" : "Logout",
    "keybind" : "o"
}
{
    "label" : "shutdown",
    "action" : "omarchy-system-shutdown",
    "text" : "Shutdown",
    "keybind" : "s"
}
{
    "label" : "suspend",
    "action" : "loginctl lock-session & sleep 1; systemctl suspend --no-wall",
    "text" : "Suspend",
    "keybind" : "u"
}
{
    "label" : "reboot",
    "action" : "omarchy-system-reboot",
    "text" : "Reboot",
    "keybind" : "r"
}
