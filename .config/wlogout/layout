{
    "label" : "lock",
    "action" : "omarchy-system-lock",
    "text" : "Lock",
    "keybind" : "l"
}
{
    "label" : "logout",
    "action" : "omarchy-system-logout",
    "text" : "Logout",
    "keybind" : "o"
}
{
    "label" : "shutdown",
    "action" : "omarchy-system-shutdown",
    "text" : "Shutdown",
    "keybind" : "s"
}
{
    "label" : "suspend",
    "action" : "omarchy-system-lock && systemctl suspend --no-wall",
    "text" : "Suspend",
    "keybind" : "u"
}
{
    "label" : "reboot",
    "action" : "omarchy-system-reboot",
    "text" : "Reboot",
    "keybind" : "r"
}
