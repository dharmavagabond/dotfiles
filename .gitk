set mainfont {{Helvetica Neue} 11}
set textfont {{Panic Sans} 11}
set uifont {{Helvetica Neue} 11}
set tabstop 8
set findmergefiles 0
set maxgraphpct 50
set maxwidth 16
set cmitmode patch
set wrapcomment none
set autoselect 1
set autosellen 40
set showneartags 1
set hideremotes 0
set showlocalchanges 1
set datetimeformat {%Y-%m-%d %H:%M:%S}
set limitdiffs 1
set uicolor #b0b8a4
set want_ttk 1
set bgcolor white
set fgcolor #111111
set colors {green red blue magenta darkgrey brown orange}
set diffcolors {red #4da066 #3f53ff}
set markbgcolor #d0d9ff
set diffcontext 3
set selectbgcolor #dadddf
set extdifftool opendiff
set perfile_attrs 0
set geometry(main) 1243x628+5+27
set geometry(state) normal
set geometry(topwidth) 1243
set geometry(topheight) 165
set geometry(pwsash0) "320 1"
set geometry(pwsash1) "480 1"
set geometry(botwidth) 400
set geometry(botheight) 458
set permviews {}
